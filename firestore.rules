rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // 🔒 CORREÇÃO: Verificar admin via claims OU via documento (fallback)
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.admin == true ||
         (isOwner(request.auth.uid) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true));
    }
    
    // 🔒 CORREÇÃO: Permitir leitura do próprio usuário para validações básicas
    function isActiveUser() {
      return request.auth != null && 
        (request.auth.token.isActive == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true);
    }
    
    match /users/{userId} {
      // 🔒 CORREÇÃO CRÍTICA: Permitir que usuário leia o próprio documento
      allow read: if isOwner(userId) || isAdmin();
      
      // Admins têm acesso total
      // Usuários podem atualizar campos específicos (incluindo 2FA)
      allow write: if 
        isAdmin() ||
        (isOwner(userId) && 
         // Permitir atualização de campos relacionados a 2FA e validade
         request.resource.data.diff(resource.data).affectedKeys().hasAll(['twoFactorEnabled', 'twoFactorURI']) &&
         request.resource.data.diff(resource.data).affectedKeys().size() == 2);
    }

    match /properties/{propertyId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
    }
  }
}